# .env.xneelo.example — Environment variables for the Xneelo VPS deployment
#
# Copy this file to .env.xneelo and fill in the real values BEFORE running
# the bootstrap script:  `cp .env.xneelo.example .env.xneelo && vim .env.xneelo`
#
# The bootstrap script (scripts/bootstrap-xneelo.sh) sources this file.

# ----------------------------------------------------------------------------
# HOST IDENTITY
# ----------------------------------------------------------------------------

# Hostname as it appears in /etc/hostname and in reverse DNS
# Xneelo panel sets this when the VPS is created
HOSTNAME="vpn-prod-01.databyte.co.za"

# Public IPv4 of the VPS (get from Xneelo panel → Cloud → Server → Networking)
PUBLIC_IPV4=""

# Default gateway IP (usually .1 of the /24, e.g. 196.x.x.1 — get from Xneelo panel)
# Run `ip route` after first SSH to confirm.
DEFAULT_GATEWAY=""

# Internal interface (Xneelo usually uses eth0 or ens3)
INTERNAL_IFACE=""

# ----------------------------------------------------------------------------
# DNS / DOMAIN
# ----------------------------------------------------------------------------

# Domain name that the strongSwan server cert will be issued for (SAN)
# MUST match the A record in Cloudflare. Cloudflare manages this DNS zone.
SERVER_ID="myvpn.databyte.co.za"

# Cloudflare manages databyte.co.za zone — see docs/CLOUDFLARE-DNS.md for required records
CLOUDFLARE_ZONE="databyte.co.za"

# ----------------------------------------------------------------------------
# FIRST USER (operator + customer demo)
# ----------------------------------------------------------------------------

# Operator account (full admin access)
OPERATOR_USER="zun-operator"
OPERATOR_VIP="10.99.0.2"

# First customer demo (you, also testing as a customer)
DEMO_CUSTOMER_USER="zun"
DEMO_CUSTOMER_VIP="10.99.0.50"

# Operator password (used as EAP-MSCHAPv2 secret for zun-operator)
# Leave empty to AUTO-GENERATE during bootstrap (recommended).
# A 32-char strong password will be written back to .env.xneelo.
OPERATOR_PASSWORD=""

# Demo customer password (used as EAP-MSCHAPv2 secret for DEMO_CUSTOMER_USER)
# Leave empty to AUTO-GENERATE during bootstrap (recommended).
DEMO_CUSTOMER_PASSWORD=""

# Pre-shared key for PSK connections (used by friend accounts)
# Leave empty to AUTO-GENERATE during bootstrap (recommended).
FRIEND_PSK=""

# ----------------------------------------------------------------------------
# SECRETS
# ----------------------------------------------------------------------------

# Generate these with: openssl rand -base64 32
# CA private key passphrase (defense in depth — not strictly required for self-signed)
# Leave empty if you don't want a passphrase (will be prompted at deploy time)
CA_KEY_PASSPHRASE=""

# ----------------------------------------------------------------------------
# BACKUP DESTINATION (RustFS on homelab)
# ----------------------------------------------------------------------------

# rclone remote name (configured during bootstrap)
RCLONE_REMOTE="rustfs"

# RustFS bucket (already created on homelab: open-claw-push)
RCLONE_BUCKET="open-claw-push"

# Backup sub-path within bucket
BACKUP_PATH="vpn-prod-01/db"

# RustFS endpoint (the OpenClaw host's S3-compatible endpoint)
RUSTFS_ENDPOINT="http://196.x.x.x:30293"

# RustFS access key + secret (get from TrueNAS → rustfs app)
RUSTFS_ACCESS_KEY=""
RUSTFS_SECRET_KEY=""

# ----------------------------------------------------------------------------
# NOTIFICATIONS (optional, for later)
# ----------------------------------------------------------------------------

# Telegram bot token for sending alerts (leave empty to disable)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=""

# Telegram chat ID for alerts (your personal chat ID = 7748884597)
TELEGRAM_CHAT_ID=""

# ----------------------------------------------------------------------------
# TIMING / SCHEDULES (all UTC, will be converted to SAST = UTC+2 for display)
# ----------------------------------------------------------------------------

# Daily DB backup cron (UTC). Default: 03:00 UTC = 05:00 SAST
BACKUP_CRON_HOUR="3"
BACKUP_CRON_MINUTE="0"

# Cert renewal check cron. Let's Encrypt certs renew at 60 days, so weekly check is fine.
CERT_CHECK_CRON_DAY="0"  # Sunday
CERT_CHECK_CRON_HOUR="4"

# ----------------------------------------------------------------------------
# NOT TOUCH (advanced)
# ----------------------------------------------------------------------------

# IKEv2 internal subnet (VPN clients get addresses from this range)
# MUST match the strongswan.d/00-virtual-ip.conf and rw-eap.conf pool
VPN_SUBNET="10.99.0.0/24"

# Docker image tag to pull from Docker Hub (or local)
# On first deploy, this will be local build if image not yet pushed.
# After first successful deploy, change to pull from Docker Hub.
DOCKER_IMAGE="zun/strongswan:6.0.7-mschapv2-attrsql"