[Unit]
Description=Periodic VPN portal smoke test (every 6h)
Documentation=https://github.com/Dippie-WP/databyte-Ikev2/blob/main/scripts/smoke.sh

[Timer]
# Every 6 hours: 00:00, 06:00, 12:00, 18:00 UTC
OnCalendar=*-*-* 00,06,12,18:00:00 UTC
# Catch up missed runs (e.g. after reboot)
Persistent=true
Unit=vpn-portal-smoke.service

[Install]
WantedBy=timers.target