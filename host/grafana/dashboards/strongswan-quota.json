      "pluginVersion": "11.4.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-default" },
          "editorMode": "code",
          "expr": "vpn_customer_data_used_bytes * on(customer) group_left(tier) vpn_customer_info",
          "format": "table",
          "instant": true,
          "legendFormat": "{{customer}}",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-default" },
          "editorMode": "code",
          "expr": "vpn_customer_data_limit_bytes",
          "format": "table",
          "instant": true,
          "legendFormat": "{{customer}}",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-default" },
          "editorMode": "code",
          "expr": "vpn_customer_over_quota",
          "format": "table",
          "instant": true,
          "legendFormat": "{{customer}}",
          "range": false,
          "refId": "C"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "customer", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Value #A": false,
              "Value #B": false,
              "Value #C": false,
              "tier": false,
              "is_operator": true,
              "is_active": true,
              "job": true,
              "instance": true
            },
            "indexByName": {
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "customer": 0,
              "tier": 1
            },
            "renameByName": {
              "Value #A": "used",
              "Value #B": "limit",
              "Value #C": "over_quota"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "pct",
            "binary": {
              "left": "used",
              "operator": "/",
              "right": "limit"
            },
            "mode": "binary",
            "reduce": { "reducer": "sum" }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "pct",
            "binary": {
              "left": "pct",
              "operator": "*",
              "right": "100"
            },
            "mode": "binary",
            "reduce": { "reducer": "sum" }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "status",
            "binary": {
              "left": "over_quota",
              "operator": "==",
              "right": "1"
            },
            "mode": "binary",
            "reduce": { "reducer": "sum" }
          }
        },
        {
          "id": "organize",
          "options": {
            "replaceFields": [
              { "name": "status", "with": "OK" }
            ]
          }
        }
      ],
      "title": "Customer Roster (live)",
      "type": "table"
