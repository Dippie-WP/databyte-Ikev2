{
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "\ud83d\udcca Overview",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Number of active IKE_SAs. Should be >= 1 when clients are connected. If 0 with expected clients: check strongswan_exporter connectivity (charon crashed or clients disconnected).",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "strongswan_ikesas_total{instance=\"vps-01\"}",
          "refId": "A"
        }
      ],
      "title": "Active IKE SAs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Active CHILD SAs (IPsec child associations). Typically 2x IKE_SA count (inbound + outbound per client). If 0 while IKE_SAs > 0: charon may have lost SA state.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "yellow",
                  "text": "NONE"
                }
              },
              "type": "value"
            }
          ]
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "strongswan_childsas_total{instance=\"vps-01\"}",
          "refId": "A"
        }
      ],
      "title": "Active CHILD SAs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "charon process uptime in seconds. Red if < 5min (just restarted). Yellow 5min-1h. Green > 1h. Restart without expected downtime = investigate (crash or manual restart?).",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 300
              },
              {
                "color": "green",
                "value": 3600
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "strongswan_charon_uptime_seconds{instance=\"vps-01\"}",
          "refId": "A"
        }
      ],
      "title": "Charon Uptime",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Number of loaded charon plugins. Stable count = healthy startup. Change = charon config changed or image rebuilt.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(strongswan_loaded_plugins{instance=\"vps-01\"} == 1)",
          "refId": "A"
        }
      ],
      "title": "Loaded Plugins",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Active SA leases from radacct (acctstoptime IS NULL). If 0 but clients are connected: radacct lagging or charon not writing. If > 0 with no active clients: stale sessions (clients dropped without Stop packet).",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vpn_active_lease_count{instance=\"vps-01-quota\"}",
          "refId": "A"
        }
      ],
      "title": "Active Leases",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Online addresses in strongSwan rw-pool (swanctl --list-pools). If 0 but active leases > 0: pool state out of sync with radacct (run swanctl --list-pools on vps-01 to verify).",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 7,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "vpn_pool_online{instance=\"vps-01-quota\"}",
          "refId": "A"
        }
      ],
      "title": "Pool Online",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 10,
      "panels": [],
      "title": "\ud83d\udc65 Per-User Traffic (Top Talkers)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Top 10 IKE SAs by bytes received (strongswan_sa_bytes_in_total). Bar gauge. Empty when no active SAs = normal when clients disconnected.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 6
      },
      "id": 11,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showValue": "always"
      },
      "targets": [
        {
          "expr": "topk(10, strongswan_sa_bytes_in_total{instance=\"vps-01\"})",
          "legendFormat": "{{remote_id}} ({{virtual_ip}})",
          "refId": "A"
        }
      ],
      "title": "Top by Bytes In (per SA)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Top 10 IKE SAs by bytes sent (strongswan_sa_bytes_out_total). Bar gauge. Empty when no active SAs = normal when clients disconnected.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 6
      },
      "id": 12,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showValue": "always"
      },
      "targets": [
        {
          "expr": "topk(10, strongswan_sa_bytes_out_total{instance=\"vps-01\"})",
          "legendFormat": "{{remote_id}} ({{virtual_ip}})",
          "refId": "A"
        }
      ],
      "title": "Top by Bytes Out (per SA)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Active SA table showing bytes in per remote_id. Configure transformations: sort by Bytes In descending, rename metric.remote_id to Client.",
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 6
      },
      "id": 13,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "strongswan_sa_bytes_in_total{instance=\"vps-01\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Active SAs",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludes": [
              {
                "name": "__name__"
              },
              {
                "name": "instance"
              },
              {
                "name": "job"
              }
            ],
            "renameByName": {
              "Value": "Bytes In",
              "metric.remote_id": "Client",
              "metric.virtual_ip": "VIP"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "sort": [
              {
                "desc": true,
                "property": "Bytes In"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "id": 20,
      "panels": [],
      "title": "\ud83d\udcc8 Throughput Over Time",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Bytes/sec received per remote_id (rate of sa_bytes_in_total[5m]). Shows current throughput per client. Zero = client disconnected or no traffic.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 21,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (remote_id) (rate(strongswan_sa_bytes_in_total{instance=\"vps-01\"}[5m]))",
          "legendFormat": "{{remote_id}}",
          "refId": "A"
        }
      ],
      "title": "Bytes/sec In (per user)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Bytes/sec sent per remote_id (rate of sa_bytes_out_total[5m]). Shows current throughput per client. Zero = client disconnected or no traffic.",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 22,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (remote_id) (rate(strongswan_sa_bytes_out_total{instance=\"vps-01\"}[5m]))",
          "legendFormat": "{{remote_id}}",
          "refId": "A"
        }
      ],
      "title": "Bytes/sec Out (per user)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 30,
      "panels": [],
      "title": "\ud83d\udda5\ufe0f Server Metrics (vps-01)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "CPU usage %% over time. Spike = process overload. Sustained high = investigate charon load (many SAs, crypto operations).",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 22
      },
      "id": 31,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{instance=\"vps-01:9100\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "title": "CPU Usage %",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Memory used = MemTotal - MemAvailable (RSS). Growing trend = memory leak (restart charon if sustained growth > 80%%).",
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 22
      },
      "id": 32,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes{instance=\"vps-01:9100\"} - node_memory_MemAvailable_bytes{instance=\"vps-01:9100\"}) / 1024 / 1024",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "title": "Memory Used (MB)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Root filesystem usage %%. Sustained > 80%% = disk pressure (log rotation needed or backup filling disk).",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 22
      },
      "id": 33,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{instance=\"vps-01:9100\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"vps-01:9100\",mountpoint=\"/\"})) * 100",
          "legendFormat": "/",
          "refId": "A"
        }
      ],
      "title": "Disk Usage %",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 40,
      "panels": [],
      "title": "\ud83d\udce6 Customer Quotas (vps-01 prod)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Cumulative data used per customer (vpn_customer_data_used_bytes). Shows how much of their monthly quota each customer has consumed.",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 29
      },
      "id": 41,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showValue": "always"
      },
      "targets": [
        {
          "expr": "topk(20, vpn_customer_data_used_bytes{instance=\"vps-01-quota\"})",
          "legendFormat": "{{customer_id}}",
          "refId": "A"
        }
      ],
      "title": "Customer Data Used (Bytes)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Customer status table: active flag, operator flag, tier name, over-quota flag. Useful for quick health check of all registered customers.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "id": 42,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "vpn_customer_info{instance=\"vps-01-quota\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Customer Status",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "id": 50,
      "panels": [],
      "title": "\ud83d\udcca Cumulative Data Usage per User (this session)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "description": "Cumulative bytes received per remote_id (strongswan_sa_bytes_in_total). Resets on IKE_SA rekey. For session-persistent byte accounting use panel 66 (radacct-based).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 39
      },
      "id": 51,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-default"
          },
          "expr": "strongswan_sa_bytes_in_total{instance=\"vps-01\"}",
          "instant": false,
          "legendFormat": "{{remote_id}}",
          "refId": "A"
        }
      ],
      "title": "Bytes In per User (cumulative)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "description": "Cumulative bytes sent per remote_id (strongswan_sa_bytes_out_total). Resets on IKE_SA rekey. For session-persistent byte accounting use panel 66 (radacct-based).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 39
      },
      "id": 52,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-default"
          },
          "expr": "strongswan_sa_bytes_out_total{instance=\"vps-01\"}",
          "instant": false,
          "legendFormat": "{{remote_id}}",
          "refId": "A"
        }
      ],
      "title": "Bytes Out per User (cumulative)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 48
      },
      "id": 60,
      "panels": [],
      "title": "\ud83e\ude7a Exporter & RADIUS Health",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "description": "1 if the quota-exporter last scrape succeeded, 0 if errored. If DOWN, run `journalctl -u quota-exporter -n 50` on vps-01.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "DOWN"
                },
                "1": {
                  "color": "green",
                  "text": "UP"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 49
      },
      "id": 61,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-default"
          },
          "expr": "vpn_exporter_up{instance=\"vps-01-quota\"}",
          "legendFormat": "Exporter Up",
          "refId": "A"
