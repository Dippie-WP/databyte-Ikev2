      "title": "Customer Data Used (Bytes)",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 29
      },
      "id": 42,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "vpn_customer_info{instance=\"vps-01-quota\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Customer Status",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 38
      },
      "id": 50,
      "panels": [],
      "title": "\ud83d\udcca Cumulative Data Usage per User (this session)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "description": "Cumulative bytes received per CHILD_SA. Lines reset on IKE_SA rekey (~4 hours for iPhone, ~50 min for Windows). Tracks per-session usage only \u2014 historical data lost when SA terminates. Source: strongswan_exporter.py :9101.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 39
      },
      "id": 51,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-default"
          },
          "expr": "strongswan_sa_bytes_in_total{instance=\"vps-01\"}",
          "instant": false,
          "legendFormat": "{{remote_id}}",
          "refId": "A"
        }
      ],
      "title": "Bytes In per User (cumulative)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-default"
      },
      "description": "Cumulative bytes sent per CHILD_SA. Lines reset on IKE_SA rekey. Source: strongswan_exporter.py :9101.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 39
      },
      "id": 52,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-default"
          },
          "expr": "strongswan_sa_bytes_out_total{instance=\"vps-01\"}",
          "instant": false,
          "legendFormat": "{{remote_id}}",
          "refId": "A"
        }
      ],
      "title": "Bytes Out per User (cumulative)",
      "type": "timeseries"
    }
  ],
