[Unit]
Description=Weekly TLS certificate expiry check (VPN portal)
Documentation=man:openssl

[Timer]
# Run weekly on Sunday at 03:00 UTC (05:00 SAST)
# 30 min before AIDE timer (which runs 02:30 UTC → wait, AIDE is 02:30, cert 03:00)
OnCalendar=Sun *-*-* 03:00:00 UTC
Persistent=true
Unit=cert-expiry-check.service

[Install]
WantedBy=timers.target
