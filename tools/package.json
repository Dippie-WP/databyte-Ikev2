{
  "name": "strongswan-vpn-portal-smoke",
  "version": "1.2.10",
  "private": true,
  "description": "Headless-browser smoke test for the databyte VPN portal UI. Catches DOM-rendering regressions that API-only tests miss (lesson learned from v1.2.7.1 el() flatten bug).",
  "scripts": {
    "smoke": "node portal-smoke.js",
    "smoke:verbose": "VERBOSE=1 node portal-smoke.js",
    "smoke:live": "PORTAL_URL=http://192.168.10.98:8080 node portal-smoke.js",
    "smoke:ci": "node portal-smoke.js",
    "install:chromium": "npx puppeteer browsers install chrome"
  },
  "dependencies": {
    "puppeteer-core": "^23.10.4"
  },
  "devDependencies": {
    "puppeteer": "^23.10.4"
  },
  "engines": {
    "node": ">=18"
  }
}
